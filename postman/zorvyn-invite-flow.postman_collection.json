{
    "info": {
        "name": "Zorvyn Invite Flow",
        "description": "Postman collection for backend-only invite onboarding flow.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:5000"
        },
        {
            "key": "adminEmail",
            "value": "admin@company.com"
        },
        {
            "key": "adminPassword",
            "value": "SecurePass123"
        },
        {
            "key": "inviteEmail",
            "value": "analyst@company.com"
        },
        {
            "key": "invitePassword",
            "value": "SecurePass123"
        },
        {
            "key": "adminToken",
            "value": ""
        },
        {
            "key": "inviteToken",
            "value": ""
        },
        {
            "key": "invitedUserToken",
            "value": ""
        }
    ],
    "item": [
        {
            "name": "Health Check",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{baseUrl}}/health",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "health"
                    ]
                }
            }
        },
        {
            "name": "Auth - Register Admin (optional)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\",\n  \"role\": \"admin\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/auth/register",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "auth",
                        "register"
                    ]
                }
            }
        },
        {
            "name": "Auth - Login Admin",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/auth/login",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "auth",
                        "login"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "const json = pm.response.json();",
                            "if (json?.data?.token) {",
                            "  pm.collectionVariables.set('adminToken', json.data.token);",
                            "}"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
        {
            "name": "Invites - Send Invite",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    },
                    {
                        "key": "Authorization",
                        "value": "Bearer {{adminToken}}"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"{{inviteEmail}}\",\n  \"role\": \"analyst\",\n  \"customMessage\": \"Join our finance team!\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/invites",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "invites"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "const json = pm.response.json();",
                            "if (json?.data?.token) {",
                            "  pm.collectionVariables.set('inviteToken', json.data.token);",
                            "}"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
        {
            "name": "Invites - Validate Token",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{baseUrl}}/api/invites/validate/{{inviteToken}}",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "invites",
                        "validate",
                        "{{inviteToken}}"
                    ]
                }
            }
        },
        {
            "name": "Invites - Accept Invite",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"token\": \"{{inviteToken}}\",\n  \"name\": \"Sarah Anderson\",\n  \"password\": \"{{invitePassword}}\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/invites/accept",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "invites",
                        "accept"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "const json = pm.response.json();",
                            "if (json?.data?.token) {",
                            "  pm.collectionVariables.set('invitedUserToken', json.data.token);",
                            "}"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
        {
            "name": "Auth - Login Invited User",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"{{inviteEmail}}\",\n  \"password\": \"{{invitePassword}}\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/auth/login",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "auth",
                        "login"
                    ]
                }
            }
        }
    ]
}