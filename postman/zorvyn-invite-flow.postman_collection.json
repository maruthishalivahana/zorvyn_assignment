    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:5000"
        },
        {
            "key": "adminEmail",
            "value": "admin@company.com"
        },
        {
            "key": "adminPassword",
            "value": "SecurePass123"
        },
        {
            "key": "inviteEmail",
            "value": "analyst@company.com"
        },
        {
            "key": "invitePassword",
            "value": "SecurePass123"
