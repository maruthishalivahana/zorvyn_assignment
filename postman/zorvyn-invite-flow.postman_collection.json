        {
            "name": "Health Check",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{baseUrl}}/health",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "health"
                    ]
                }
            }
        },
        {
            "name": "Auth - Register Admin (optional)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\",\n  \"role\": \"admin\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/auth/register",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "auth",
                        "register"
                    ]
                }
            }
        },
        {
            "name": "Auth - Login Admin",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/api/auth/login",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "api",
                        "auth",
                        "login"
                    ]
                }
            },
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "const json = pm.response.json();",
                            "const setCookie = pm.response.headers.get('Set-Cookie');",
                            "if (setCookie) {",
                            "  const cookiePair = setCookie.split(';')[0];",
                            "  const separatorIndex = cookiePair.indexOf('=');",
                            "  if (separatorIndex > -1) {",
                            "    const token = cookiePair.slice(separatorIndex + 1);",
                            "    pm.collectionVariables.set('adminToken', token);",
                            "    pm.collectionVariables.set('activeToken', token);",
                            "  }",
                            "}",
                            "if (json?.data?.token) {",
                            "  pm.collectionVariables.set('adminToken', json.data.token);",
                            "  pm.collectionVariables.set('activeToken', json.data.token);",
                            "}"
                        ],
                        "type": "text/javascript"
                    }
                }
            ]
        },
