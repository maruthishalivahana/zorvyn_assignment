                            "script": {
                                "exec": [
                                    "const json = pm.response.json();",
                                    "const users = json?.data?.users || json?.data?.data?.users || [];",
                                    "const target = users.find((u) => u?.email === pm.collectionVariables.get('inviteEmail')) || users.find((u) => u?.role !== 'admin');",
